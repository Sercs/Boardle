{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "boardle",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "boardle-assets"
    }
  ]
}
